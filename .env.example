# Copy this file to ".env" in the project root and edit values as needed

# === API Keys (optional; yfinance doesn't need keys) ===
ALPHA_VANTAGE_API_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === Trading Parameters ===
INITIAL_CAPITAL=10000
RISK_PER_TRADE=0.02
MAX_POSITIONS=5

# === Mean Reversion Parameters ===
LOOKBACK_PERIOD=20
ZSCORE_ENTRY=2.0
ZSCORE_EXIT=0.0
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04

# === Cost Assumptions (basis points: 1 bps = 0.01%) ===
FEE_BPS=1.0
SLIPPAGE_BPS=1.0

# === Data Params ===
FOREX_PAIRS=EURUSD=X,GBPUSD=X,USDJPY=X,AUDUSD=X,USDCAD=X
TIMEFRAME=1h
PERIOD=6mo
DATA_DIR=data
REPORTS_DIR=reports
CACHE=true
